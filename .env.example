# Mklan Studio environment variables
# Copy this file to .env and adjust values for your machine.
# Never commit .env.

# Backend
PYTHONPATH=/app
ENVIRONMENT=production
STUDIO_DATA_ROOT=/app/data
STUDIO_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
STUDIO_API_KEY=
STUDIO_MODEL_UPLOAD_MAX_BYTES=34359738368
STUDIO_IMAGE_UPLOAD_MAX_BYTES=104857600
STUDIO_DATASET_ZIP_MAX_BYTES=2147483648

# Docker build
# Use Dockerfile for the lightweight backend. Set Dockerfile.gpu when you want
# CUDA/PyTorch/sd-scripts installed inside the backend image.
BACKEND_DOCKERFILE=Dockerfile

# Training and captioning
# Keep dry-run enabled for a clean public checkout. Set false only after you have
# configured a working trainer runtime and local model files.
STUDIO_TRAINING_DRY_RUN=true
STUDIO_SD_SCRIPTS_ROOT=/app/trainers/sd-scripts
STUDIO_ACCELERATE_BIN=accelerate
STUDIO_Z_IMAGE_TRAIN_SCRIPT=

# Caption scan providers:
# - auto: local BLIP first, then KoboldCPP/vLLM, then CLIP tagger, then filename fallback.
# - local_blip: use the Hugging Face image captioning model.
# - koboldcpp_vlm: use an OpenAI-compatible vision chat endpoint.
# - clip_tagger: score a configured tag vocabulary with a CLIP/OpenCLIP model.
# - filename_fallback: derive weak captions from filename/context only.
STUDIO_CAPTION_MODEL_ID=Salesforce/blip-image-captioning-base
STUDIO_CAPTION_ALLOW_DOWNLOAD=false
STUDIO_DISABLE_LOCAL_CAPTIONING=false
STUDIO_CAPTION_PROVIDER=auto

# CLIP tagger options
STUDIO_CAPTION_CLIP_MODEL_ID=OysterQAQ/DanbooruCLIP
STUDIO_CAPTION_CLIP_MODEL_SOURCE=auto
STUDIO_CAPTION_CLIP_ALLOW_DOWNLOAD=false
STUDIO_CAPTION_CLIP_CACHE_DIR=/app/data/models/captioning/hf-cache
STUDIO_CAPTION_CLIP_TAGS_PATH=/app/data/models/captioning/tag_vocab/default_tags.txt
STUDIO_CAPTION_CLIP_TOP_K=24
STUDIO_CAPTION_CLIP_THRESHOLD=0
STUDIO_CAPTION_CLIP_MAX_CANDIDATES=256
STUDIO_CAPTION_CLIP_PROMPT_TEMPLATE={tag}

# KoboldCPP/vLLM caption options
STUDIO_CAPTION_VLM_ENDPOINT=
STUDIO_CAPTION_VLM_MODEL=
STUDIO_CAPTION_VLM_API_KEY=
STUDIO_CAPTION_VLM_TIMEOUT_S=120
STUDIO_CAPTION_VLM_PROMPT=

# Optional semantic search
STUDIO_SEMANTIC_SEARCH_ENABLED=true
STUDIO_SEMANTIC_MODEL=media-indexer/pgvector

# Wildcard module
WILDCARD_SOURCE_ROOT=/app/data/wildcards
WILDCARD_WORKSHOP_DATA_DIR=/app/data/wildcards
WILDCARD_WORKSHOP_DB=/app/data/wildcards/wildcard_workshop.db
WILDCARD_EXPORT_ROOT=/app/data/exports

# Movie module
MOVIE_DATA_DIR=/app/data/movie
MOVIE_DB=/app/data/movie/movie_tool.db
MOVIE_TOOL_SCENARIO_ASSISTANT_PROVIDER=koboldcpp
MOVIE_TOOL_SCENARIO_ASSISTANT_BASE_URL=http://host.docker.internal:5001/v1
MOVIE_TOOL_SCENARIO_ASSISTANT_MODEL=koboldcpp
MOVIE_TOOL_IMAGE_MODEL_ROOT=/app/data/models/images
MOVIE_TOOL_VIDEO_MODEL_ROOT=/app/data/models/video
MOVIE_TOOL_IMAGE_PROVIDER=comfyui
MOVIE_TOOL_IMAGE_DEFAULT_MODEL=
MOVIE_TOOL_COMFY_ENDPOINT=http://host.docker.internal:8188
MOVIE_TOOL_COMFY_TIMEOUT_S=300
MOVIE_TOOL_IMAGE_SAMPLER=LCM
MOVIE_TOOL_IMAGE_SCHEDULER=simple
MOVIE_TOOL_IMAGE_STEPS=12
MOVIE_TOOL_IMAGE_CFG_SCALE=1
MOVIE_TOOL_SCENARIO_ASSISTANT_API_KEY=
MOVIE_TOOL_SCENARIO_ASSISTANT_TIMEOUT_S=120
MOVIE_TOOL_FFMPEG_BINARY=ffmpeg
MOVIE_TOOL_ALLOW_PLACEHOLDER_RENDERER=true
MOVIE_TOOL_SUPPORTED_MIN_VRAM_GB=16
MOVIE_TOOL_DEFAULT_WIDTH=1280
MOVIE_TOOL_DEFAULT_HEIGHT=720
MOVIE_TOOL_DEFAULT_FPS=24
MOVIE_TOOL_DEFAULT_TARGET_DURATION_S=240

# SillyTavern Cards module
CARDS_DATA_DIR=/app/data/cards
CARDS_DB=/app/data/cards/card_creator.db
CARDS_SILLYTAVERN_ENABLED=true
CARDS_SILLYTAVERN_DATA_ROOT=/sillytavern-data
SILLYTAVERN_PUBLIC_URL=http://localhost:8011
SILLYTAVERN_INTERNAL_URL=http://sillytavern:8000
SILLYTAVERN_PUBLIC_PORT=8011
SILLYTAVERN_VERSION=latest
SILLYTAVERN_BIND_ADDR=127.0.0.1
SILLYTAVERN_WHITELISTMODE=true
SILLYTAVERN_WHITELIST=["::1","127.0.0.1","172.16.0.0/12"]
SILLYTAVERN_SECURITYOVERRIDE=false

# ComfyUI integration
COMFYUI_CUSTOM_NODES_DIR=/app/data/integrations/comfyui

# Media Indexer integration
# Enable with: docker compose --profile media-indexer up -d --build
# Replace both values before running the profile.
MEDIA_INDEXER_BASIC_SCAN_BATCH_SIZE=1000
MEDIA_INDEXER_POSTGRES_PASSWORD=CHANGE_ME_media_indexer_db_password
MEDIA_INDEXER_SESSION_SECRET=CHANGE_ME_generate_a_long_random_secret
MEDIA_INDEXER_INTERNAL_URL=http://media_indexer_backend:8000
MEDIA_INDEXER_TIMEOUT_S=10
MEDIA_INDEXER_APP_ENV=production
MEDIA_INDEXER_AUTO_SYNC_GENERATED=true
MEDIA_INDEXER_AUTO_SCAN_MODE=metadata
MEDIA_INDEXER_GENERATED_SOURCE_NAME=Mklan Studio Generated
MEDIA_INDEXER_GENERATED_SOURCE_ROOT=/data/sources/generated

# GPU container hints, used only when you opt into a GPU backend override.
NVIDIA_VISIBLE_DEVICES=all
NVIDIA_DRIVER_CAPABILITIES=compute,utility
